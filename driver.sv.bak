//driver class      
class driver;

virtual intf vif;
mailbox gen2driv;
int no_of_transaction;
//customized constructor with two inputs interface and mailbox as input
function new(virtual intf vif,mailbox gen2driv);
this.gen2driv=gen2driv;
this.vif=vif;
endfunction

//reset task
task reset;
wait(vif.rst_n==0);
$display("Driver::reset started");
//reset all signals here
vif.w_en<=0;
vif.r_en<=0;
vif.cs<=0;
vif.data_in<=0;
wait(vif.rst_n);
$display("Driver::reset ended");
endtask

task main;
forever begin
transcation t;
 //t=new();
gen2driv.get(t);
@(posedge vif.clk);
vif.cs<=t.cs;
vif.w_en<=t.w_en;
vif.r_en<=t.r_en;
vif.data_in<=t.data_in;
@(posedge vif.clk);
t.display("driver");
no_of_transaction++;
//$display("DRIVER: w_en=%0d r_en=%0d data_in=%0d",vif.w_en, vif.r_en, vif.data_in);
end
endtask

endclass
